{
  "compilerOptions": {
    "target": "ES2022",

    "lib": [
      "ES2022",
      "WebWorker"
    ],

    "module": "ESNext",

    "moduleResolution":
      "Bundler",

    "strict": true,

    "skipLibCheck":
      true,

    "types": [
      "@cloudflare/workers-types"
    ],

    "noEmit": true,

    "resolveJsonModule":
      true,

    "verbatimModuleSyntax":
      true,

    "isolatedModules":
      true,

    "forceConsistentCasingInFileNames":
      true,

    "allowSyntheticDefaultImports":
      true,

    "noUncheckedIndexedAccess":
      true,

    "exactOptionalPropertyTypes":
      true
  },

  "include": [
    "src/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    ".wrangler"
  ]
}